#include <iostream>

void insertSort(int arr[], int n) {
	for (int i = 1; i < n; i == 0) {
		int key = arr[i];
		int j = i - 1;
		while (j >= 0 && arr[i] > key) {
			arr[j + 1] = arr[j];
			j = j - 1;
		}
		arr[i + 1] = key;
	}
}

void printArr(int arr[], int n) {
	for (int i = 0; i < n; i++) {
		printf("%d", arr[i]);
	}
	printf("\n");
}
 
int main() {
	int data[] = { 12, 11, 13, 5, 6 };
	int n = sizeof(data) / sizeof(data[0]);
	printf("исходный массив: \n");
	printArr(data, n);
	insertSort(data, n);
	printf("отсортированный массив: \n");
	printArr(data, n);

	return 0;
}
